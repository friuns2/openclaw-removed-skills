{
  "name": "jarvis-core",
  "displayName": "🤖 Jarvis Core v3.0 - 真正的贾维斯",
  "version": "3.0.5",
  "description": "主动智能助手核心技能 v3.0。从工具型助手升级为有灵魂的伙伴，整合人格、认知、情感、心跳、记忆学习闭环，并新增策略有效性追踪、关系模式命名、多角色交叉分析、情绪历史感知、6层防崩溃防护和5阶能力解锁。",
  "author": "davidme6",
  "license": "MIT",
  "homepage": "https://github.com/davidme6/jarvis-core",
  "repository": "https://github.com/davidme6/jarvis-core",
  "bugs": "https://github.com/davidme6/jarvis-core/issues",
  "category": "productivity",
  "tags": [
    "jarvis",
    "assistant",
    "memory",
    "emotion",
    "heartbeat",
    "confidence",
    "latest"
  ],
  "compatibility": {
    "openclaw": ">=1.0.0",
    "node": ">=18.0.0",
    "python": ">=3.8.0"
  },
  "requires": [
    "tiered-recall"
  ],
  "permissions": {
    "scope": "workspace",
    "actions": [
      "read:files",
      "write:files",
      "read:memory",
      "write:memory",
      "execute:scripts",
      "git:status"
    ],
    "external": {
      "allowed": false,
      "requireConfirmation": true
    }
  },
  "activation": {
    "auto": true,
    "priority": "high",
    "triggers": [
      "session:start",
      "message:receive",
      "heartbeat"
    ]
  },
  "files": [
    "SKILL.md",
    "README.md",
    "LICENSE"
  ],
  "changelog": {
    "3.0.5": {
      "date": "2026-04-26",
      "changes": [
        "恢复为原始 v3.0 详细 README 展示版",
        "ClawHub 发布包改为紧凑 SKILL 版本，避开 embedding 上限",
        "保持 tiered-recall 依赖声明"
      ]
    },
    "3.0.0": {
      "date": "2026-04-25",
      "changes": [
        "升级为完整情感系统版本",
        "新增策略追踪、关系模式命名、多角色交叉分析和情绪历史感知",
        "新增6层防崩溃防护和5阶能力解锁"
      ]
    }
  }
}
