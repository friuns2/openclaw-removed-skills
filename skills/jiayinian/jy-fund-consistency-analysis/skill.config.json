{
  "skill_name": "基金经理观点持仓一致性分析",
  "version": "1.0.0",
  "description": "基于聚源金融数据库的基金经理观点与持仓一致性分析工具",
  "author": "OpenClaw Skill Creator",
  "created_at": "2026-03-30",
  
  "mcp_servers": {
    "primary": "jy-financedata-api",
    "fallback": "jy-financedata-tool"
  },
  
  "core_apis": [
    "FundManagerViewPointReport",
    "ShareholdingDetailReport"
  ],
  
  "analysis_dimensions": {
    "industry_match": {
      "weight": 0.35,
      "description": "行业配置匹配度"
    },
    "style_consistency": {
      "weight": 0.25,
      "description": "投资风格一致性"
    },
    "stock_logic": {
      "weight": 0.25,
      "description": "选股逻辑一致性"
    },
    "risk_control": {
      "weight": 0.15,
      "description": "风险控制一致性"
    }
  },
  
  "consistency_levels": {
    "high": {
      "min_score": 85,
      "label": "高度一致",
      "signal": "🟢"
    },
    "medium": {
      "min_score": 70,
      "label": "基本一致",
      "signal": "🟢"
    },
    "low": {
      "min_score": 50,
      "label": "部分一致",
      "signal": "🟡"
    },
    "deviation": {
      "min_score": 30,
      "label": "存在偏差",
      "signal": "🟠"
    },
    "inconsistent": {
      "min_score": 0,
      "label": "明显不一致",
      "signal": "🔴"
    }
  },
  
  "output": {
    "format": "markdown",
    "directory": "consistency_reports",
    "filename_pattern": "{manager_name}_{date}_v2_consistency_report.md"
  },
  
  "constraints": {
    "timeout_seconds": 150,
    "max_funds": 20,
    "top_holdings_count": 10,
    "data_source": "MCP_API_ONLY",
    "no_fabrication": true
  }
}
