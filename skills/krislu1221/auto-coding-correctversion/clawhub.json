{
  "name": "auto-coding",
  "version": "2.1.1",
  "description": "Auto-Coding - 自主编程系统，具备自我反思能力，测试→反思→修复循环，达到交付标准",
  "author": "Krislu + nanobot",
  "license": "Internal",
  "tags": ["coding", "automation", "self-reflection", "quality", "delivery"],
  "triggers": [
    "/auto-coding\\s+(.+)",
    "/coding\\s+(.+)",
    "帮我创建一个 (.+)",
    "帮我开发一个 (.+)",
    "这个功能怎么实现(.+)",
    "我需要写一个 (.+)"
  ],
  "examples": [
    "/auto-coding 创建一个批量重命名文件的脚本",
    "/auto-coding mode thorough 创建一个天气查询 Web 应用",
    "帮我开发一个天气查询 Web 应用",
    "这个功能怎么实现？我需要给 EC Dashboard 添加实例健康检查"
  ],
  "dependencies": [
    "ddgs (optional, for web search)"
  ],
  "files": [
    "SKILL.md",
    "README.md",
    "USAGE.md",
    "worker.py",
    "self_reflect.py",
    "delivery_check.py",
    "__init__.py"
  ],
  "entry_point": "worker.py",
  "config": {
    "default_mode": "standard",
    "default_reflect_depth": "deep",
    "max_iterations": 5,
    "delivery_standards": {
      "runs_without_error": true,
      "has_basic_tests": true,
      "has_documentation": true,
      "has_error_handling": true,
      "security_check_passed": true
    }
  },
  "changelog": {
    "1.0.0": {
      "date": "2026-03-15",
      "changes": [
        "初始版本",
        "核心工作流实现 (worker.py)",
        "自我反思模块 (self_reflect.py)",
        "交付标准检查 (delivery_check.py)",
        "提示词模板 (prompts/)",
        "测试套件 (tests/)"
      ]
    }
  }
}
